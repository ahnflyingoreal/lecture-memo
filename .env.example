# Neon — 앱 런타임 (pooled, Vercel은 POSTGRES_PRISMA_URL 자동 주입)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# 빌드 시 migrate용 (unpooled / direct) — Vercel은 POSTGRES_URL_NON_POOLING 자동 주입
# 로컬에서 migrate 할 때만 필요하면 동일 호스트의 non-pooler URL 사용
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
